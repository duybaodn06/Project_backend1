mixin alertSuccess(time)
    - if (messages.success)
        message.info
            div(
                class="alert alert-success"
                data-time=time
                show-alert
            )  <span close-alert> x </span> #{messages.success}

mixin alertError(time)
    - if (messages.error)
        message.info
            div(
                class="alert alert-danger"
                data-time=time
                show-alert
            )  <span close-alert> x </span> #{messages.error}